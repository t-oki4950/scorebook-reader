{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Scorebook Symbol Dictionary",
  "type": "object",
  "required": ["schema_version", "rules"],
  "additionalProperties": true,
  "properties": {
    "schema_version": { "type": "string" },
    "description": { "type": "string" },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "symbol", "category", "reading", "description"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string" },
          "symbol": { "type": "string" },
          "aliases": {
            "type": "array",
            "items": { "type": "string" }
          },
          "category": { "type": "string" },
          "reading": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    }
  }
}
